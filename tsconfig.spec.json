/* Configuracao TypeScript usada pelos testes. */
{
  "extends": "./tsconfig.json",
  /* Ativa tipos do Jasmine para ficheiros de teste. */
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jasmine"
    ]
  },
  /* Inclui apenas definicoes e ficheiros spec. */
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts"
  ]
}
