# Define regras simples de formatacao do editor.
root = true

# Regras gerais para todos os ficheiros.
[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Regras usadas nos ficheiros TypeScript.
[*.ts]
quote_type = single
ij_typescript_use_double_quotes = false

# Regras usadas na documentacao.
[*.md]
max_line_length = off
trim_trailing_whitespace = false
