/* Configuracao TypeScript usada pela aplicacao Angular. */
{
  "extends": "./tsconfig.json",
  /* Pasta onde o Angular coloca ficheiros compilados temporarios. */
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": []
  },
  /* Inclui todos os ficheiros TypeScript da aplicacao. */
  "include": [
    "src/**/*.ts"
  ],
  /* Exclui ficheiros de testes desta compilacao. */
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
